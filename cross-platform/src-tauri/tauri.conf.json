{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "withGlobalTauri": true,
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "PinStick",
    "version": "2.6.0"
  },
  "tauri": {
    "security": {
      "csp": "default-src 'self' tauri: asset: data: blob:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:"
    },
    "bundle": {
      "active": true,
      "identifier": "slf.pinstick",
      "macOS": {
        "signingIdentity": "-"
      },
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "PinStick",
        "width": 420,
        "height": 320,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  }
}
